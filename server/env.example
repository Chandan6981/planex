# PlanEx — Environment Variables

#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your values in .env
#   3. Never commit .env to git — it's already in .gitignore
#
# REQUIRED vs OPTIONAL:
#   [REQUIRED] — server will crash on startup if missing
#   [OPTIONAL] — feature is disabled gracefully if missing
#

# CORE — [REQUIRED]


# MongoDB connection string
# Local:   mongodb://localhost:27017/planex
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/planex
MONGO_URI=mongodb://localhost:27017/planex

# JWT secret for signing access tokens (15 min expiry)
# Must be a long random string — minimum 32 characters
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string_minimum_32_chars

# Separate secret for refresh tokens (7 day expiry)
# MUST be different from JWT_SECRET
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
REFRESH_TOKEN_SECRET=replace_this_with_a_different_long_random_string

# Port the Express server listens on
PORT=5000

# URL of the React frontend — used for CORS and email links
# Development: http://localhost:3000
# Production:  https://yourdomain.com
CLIENT_URL=http://localhost:3000

# Node environment — affects cookie security (secure: true only in production)
# Values: development | production
NODE_ENV=development


# AWS — [OPTIONAL]
# If not set, file uploads and email notifications are disabled gracefully.
# The app runs fully without these configured.
# AWS region where your S3 bucket and SQS queue live
# Example: us-east-1 | eu-north-1 | ap-south-1
AWS_REGION=eu-north-1

# IAM user credentials — needs AmazonS3FullAccess + AmazonSQSFullAccess
# Create at: AWS Console → IAM → Users → Add User → Programmatic access
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY


# AWS S3 — File & Audio Storage [OPTIONAL]
# S3 bucket for storing task attachments and voice comment audio files
#
# Setup:
#   1. Create S3 bucket → uncheck "Block all public access"
#   2. Add bucket policy allowing public read on /*
#   3. Add CORS config allowing your CLIENT_URL
#
# Files are stored at:
#   taskflow/tasks/{taskId}/{timestamp}-{random}.ext        (attachments)
#   taskflow/voice-comments/{taskId}/{timestamp}.webm       (voice comments)

AWS_S3_BUCKET=your-planex-bucket-name


# AWS SQS — Async Email Queue [OPTIONAL]

# FIFO queue for async email notifications
# Without this, emails are not sent but the app works fine
#
# Setup:
#   1. Create SQS FIFO queue — name MUST end with .fifo
#   2. Enable content-based deduplication: ON
#   3. Configure Dead Letter Queue (recommended):
#      a. Create standard SQS queue: planex-notifications-dlq
#      b. On FIFO queue → Edit → Dead-letter queue → set to planex-notifications-dlq
#      c. Set maxReceiveCount = 3
#   4. Copy the Queue URL below
#   5. Run the worker separately: node queueWorker.js
#
# Queue URL format:
#   https://sqs.{region}.amazonaws.com/{accountId}/{queueName}.fifo

AWS_SQS_QUEUE_URL=https://sqs.eu-north-1.amazonaws.com/123456789012/planex-notifications.fifo


# EMAIL — Gmail SMTP [OPTIONAL]
# Used by queueWorker.js to send email notifications
# Without this, queueWorker.js will exit on startup
#
# Setup (Gmail):
#   1. Google Account → Security → 2-Step Verification → Enable
#   2. Google Account → Security → App passwords → Generate
#   3. Select app: Mail, Select device: Other → Generate
#   4. Copy the 16-character password into EMAIL_PASS below
#
# Note: Use an App Password, NOT your regular Gmail password

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx
EMAIL_FROM=PlanEx <your_email@gmail.com>

# QUICK START CHECKLIST
#
# Minimum to run the app locally:
#   [x] MONGO_URI          — local MongoDB running
#   [x] JWT_SECRET         — any long random string
#   [x] REFRESH_TOKEN_SECRET — different long random string
#   [x] PORT               — 5000
#   [x] CLIENT_URL         — http://localhost:3000
#   [x] NODE_ENV           — development
#
# To enable file uploads (S3):
#   [ ] AWS_REGION
#   [ ] AWS_ACCESS_KEY_ID
#   [ ] AWS_SECRET_ACCESS_KEY
#   [ ] AWS_S3_BUCKET
#
# To enable email notifications (SQS + SMTP):
#   [ ] AWS_SQS_QUEUE_URL
#   [ ] EMAIL_HOST / EMAIL_PORT / EMAIL_USER / EMAIL_PASS / EMAIL_FROM
#   [ ] Run: node queueWorker.js in a separate terminal
#

